<script>
document.addEventListener("DOMContentLoaded", function() {
    // Define excluded hostnames array with the specific URL to exclude
    var excludedHostnames = [
        "stagedigitalindia-cdn.digitalindiacorporation.in"
    ];
    
    // Get all links
    var links = document.getElementsByTagName("a");

    for (var i = 0; i < links.length; i++) {
        var link = links[i];
        var href = link.getAttribute("href");
        
        // Handle cases where href is null, empty, or javascript:
        if (href && href !== "javascript:;" && href !== "#") {
            var linkHostname = (new URL(href, location.href)).hostname;

            // Check if the link is external and not in the excluded list
            if (linkHostname !== location.hostname && excludedHostnames.indexOf(linkHostname) === -1) {
                link.target = "_blank"; // Open external links in a new tab
                link.addEventListener("click", function(e) {
                    var confirmation = confirm("You are being redirected to an external website. Please note that Digital India Website cannot be held responsible for external websites' content & privacy policies.");
                    if (!confirmation) {
                        e.preventDefault(); // Prevent the link from being followed if user clicks 'No'
                    }
                });
            }
        }
    }
});
</script>
