<script>
  // Load custom language stylesheet
  function loadStylesheet(url) {
    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.type = 'text/css';
    link.href = url;
    document.head.appendChild(link);
  }

  loadStylesheet("https://cdn.digitalindiacorporation.in/wp-content/themes/di-child/assets/language/lan.css");

  // Wait for Bhashini dropdown to load
  document.addEventListener('DOMContentLoaded', function () {
    /* function waitForDropdown() {
      var dropdown = document.getElementById('translate-plugin-target-language-list');
