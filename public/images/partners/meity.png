        slidesToScroll: 1,
        dots: false,
        arrows: true
      }
    }, {
      breakpoint: 480,
      settings: {
        slidesToShow: 1,
        slidesToScroll: 1,
        arrows: true
      }
    }]
  });
  $('.variable-width').slick({
