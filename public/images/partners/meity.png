            dropdown.options[i].text = 'हिन्दी';
          }
          if (value !== 'en' && value !== 'hi') {
            dropdown.remove(i);
          }
        }

        var pluginContainer = document.getElementById('bhashini-translation');
        if (pluginContainer) {
          document.getElementById('language-dropdown').appendChild(pluginContainer);
        }
      } else {
        setTimeout(waitForDropdown, 100);
      }
    }

    waitForDropdown(); */

    var pluginContainer = document.getElementById('bhashini-translation');
        if (pluginContainer) {
            document.getElementById('language-dropdown').appendChild(pluginContainer);
        }
    });
    $(document).ready(function () {
        // Keep only English and Hindi language options
        $('.language-option').each(function () {
            var lang = $(this).data('value');
            if (lang !== 'en' && lang !== 'hi') {
            $(this).remove();
            }
        });

        // Change the button label to show only 'हिन्दी' but do NOT break plugin behavior
