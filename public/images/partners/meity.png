			<span class="browser-title" aria-hidden="true"><# print( 'Digital India | Leading the transformation in India for ease of living and digital economy | MeitY, Government of India' ) #></span>
		</div>

		<strong aria-hidden="true">As an app icon</strong>
		<div class="app-icon-preview">
			<img id="preview-app-icon" src="{{ data.url }}" alt="Preview as an app icon" />
		</div>
	</script>

